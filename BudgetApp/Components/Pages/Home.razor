@page "/"
@rendermode InteractiveServer
@using BudgetApp.Models
@using BudgetApp.Services
@inject IBudgetService BudgetService

<PageTitle>Бюджет - Головна</PageTitle>

<div class="dashboard-container">
    <h3 class="wallet-title">Мій гаманець</h3>

    <div class="transaction-form">
        <input class="form-input" @bind="newDescription" placeholder="Що купили/отримали?" />

        <select class="form-select" @bind="newType">
            <option value="@TransactionType.Expense">Витрата</option>
            <option value="@TransactionType.Income">Прибуток</option>
        </select>

        <input class="form-input" @bind="newAmount" type="number" placeholder="Сума" />

        <button class="btn-submit" @onclick="AddTransaction">Додати запис</button>
    </div>

    <h4 class="history-title">Історія транзакцій</h4>

    @if (transactions == null)
    {
        <p class="status-text">Завантаження...</p>
    }
    else if (transactions.Count == 0)
    {
        <p class="status-text">Записів ще немає.</p>
    }
    else
    {
        <ul class="transaction-list">
            @foreach (var t in transactions)
            {
                <li class="transaction-item">
                    <div class="item-info">
                        <span class="transaction-date">@t.Date.ToString("dd.MM HH:mm")</span>
                        <strong class="transaction-desc">@t.Description</strong>
                    </div>
                    <span class="transaction-amount @(t.Type == TransactionType.Income ? "income" : "expense")">
                        @(t.Type == TransactionType.Income ? "+" : "-")@t.Amount ₴
                    </span>
                </li>
            }
        </ul>
    }
</div>

@code {
    private List<Transaction> transactions = new();
    private string newDescription = "";
    private decimal newAmount = 0;
    private TransactionType newType = TransactionType.Expense;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        transactions = await BudgetService.GetTransactionsAsync();
    }

    private async Task AddTransaction()
    {
        if (string.IsNullOrWhiteSpace(newDescription) || newAmount <= 0) return;

        var t = new Transaction
        {
            Description = newDescription,
            Amount = newAmount,
            Date = DateTime.Now,
            Type = newType
        };

        await BudgetService.AddTransactionAsync(t);

        newDescription = "";
        newAmount = 0;

        await LoadData();
    }
}
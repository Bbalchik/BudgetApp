@page "/"
@rendermode InteractiveServer
@using BudgetApp.Models
@using BudgetApp.Services
@inject IBudgetService BudgetService

<PageTitle>Бюджет - Головна</PageTitle>

<div class="dashboard-container">
    <div class="month-selector">
        <button class="btn-icon" @onclick="PreviousMonth">◀</button>
        <h3 class="current-month">@GetMonthName(selectedMonth) @selectedYear</h3>
        <button class="btn-icon" @onclick="NextMonth">▶</button>
    </div>

    <div class="tabs">
        <button class="tab @(activeTab == TransactionType.Expense ? "active expense-tab" : "")" 
                @onclick="() => SetTab(TransactionType.Expense)">
            Витрати
        </button>
        <button class="tab @(activeTab == TransactionType.Income ? "active income-tab" : "")" 
                @onclick="() => SetTab(TransactionType.Income)">
            Прибуток
        </button>
    </div>

    <div class="stats-card">
        <p>Усього за місяць:</p>
        <h2 class="@(activeTab == TransactionType.Income ? "income" : "expense")">
            @(activeTab == TransactionType.Income ? "+" : "-")@GetTotalAmount() ₴
        </h2>
    </div>

    <div class="transaction-form">
        <input class="form-input" @bind="newDescription" placeholder="Назва (наприклад, Сільпо)" />
        
        <select class="form-select" @bind="newCategory">
            @foreach (var cat in currentCategories)
            {
                <option value="@cat">@cat</option>
            }
        </select>

        <input class="form-input" @bind="newAmount" type="number" placeholder="Сума (₴)" />
        
        <button class="btn-submit" @onclick="AddTransaction">Додати</button>
    </div>

    <h4 class="history-title">Історія за @GetMonthName(selectedMonth)</h4>

    @if (transactions == null)
    {
        <p class="status-text">Завантаження...</p>
    }
    else if (!FilteredTransactions.Any())
    {
        <p class="status-text">У цьому місяці записів ще немає. Гуляємо! 🎉</p>
    }
    else
    {
        <ul class="transaction-list">
            @foreach (var t in FilteredTransactions)
            {
                <li class="transaction-item">
                    <div class="item-info">
                        <span class="transaction-category">@t.Category</span>
                        <strong class="transaction-desc">@t.Description</strong>
                        <span class="transaction-date">@t.Date.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                    <div class="actions">
                        <span class="transaction-amount @(t.Type == TransactionType.Income ? "income" : "expense")">
                            @(t.Type == TransactionType.Income ? "+" : "-")@t.Amount ₴
                        </span>
                        <button class="btn-delete" @onclick="() => DeleteTransaction(t.Id)" title="Видалити">🗑</button>
                    </div>
                </li>
            }
        </ul>
    }
</div>

@code {
    private List<Transaction> transactions = new();
    
    private int selectedMonth = DateTime.Now.Month;
    private int selectedYear = DateTime.Now.Year;
    private TransactionType activeTab = TransactionType.Expense;

    private string newDescription = "";
    private decimal newAmount = 0;
    private string newCategory = "🛒 Продукти"; 

    private List<string> expenseCategories = new() { "🛒 Продукти", "🍽 Кафе", "🚕 Транспорт", "💊 Аптеки", "🏠 Комуналка", "📦 Інше" };
    private List<string> incomeCategories = new() { "💰 Зарплата", "💳 Переказ", "🎁 Подарунок", "📈 Відсотки", "📦 Інше" };
    
    private List<string> currentCategories => activeTab == TransactionType.Expense ? expenseCategories : incomeCategories;

    private IEnumerable<Transaction> FilteredTransactions => transactions
        .Where(t => t.Date.Month == selectedMonth && t.Date.Year == selectedYear && t.Type == activeTab)
        .OrderByDescending(t => t.Date);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        UpdateDefaultCategory();
    }

    private async Task LoadData()
    {
        transactions = await BudgetService.GetTransactionsAsync();
    }

    private void SetTab(TransactionType type)
    {
        activeTab = type;
        UpdateDefaultCategory();
    }

    private void UpdateDefaultCategory()
    {
        newCategory = currentCategories.First();
    }

    private void PreviousMonth()
    {
        if (selectedMonth == 1) { selectedMonth = 12; selectedYear--; }
        else { selectedMonth--; }
    }

    private void NextMonth()
    {
        if (selectedMonth == 12) { selectedMonth = 1; selectedYear++; }
        else { selectedMonth++; }
    }

    private decimal GetTotalAmount()
    {
        return FilteredTransactions.Sum(t => t.Amount);
    }

    private string GetMonthName(int month)
    {
        string[] months = { "Січень", "Лютий", "Березень", "Квітень", "Травень", "Червень", "Липень", "Серпень", "Вересень", "Жовтень", "Листопад", "Грудень" };
        return months[month - 1];
    }

    private async Task AddTransaction()
    {
        if (string.IsNullOrWhiteSpace(newDescription) || newAmount <= 0) return;

        var t = new Transaction
        {
            Description = newDescription,
            Amount = newAmount,
            Date = DateTime.Now,
            Type = activeTab, 
            Category = newCategory
        };

        await BudgetService.AddTransactionAsync(t);
        
        newDescription = "";
        newAmount = 0;
        
        await LoadData();
    }

    private async Task DeleteTransaction(Guid id)
    {
        await BudgetService.DeleteTransactionAsync(id);
        await LoadData();
    }
}